
#include <Servo.h>
Servo servoMain;
const int lightPin = A0; 

void setup()
{
    Serial.begin(9600);
   servoMain.attach(10); 
}

void loop()
{
  int lightValue = analogRead(lightPin);
  float voltage = lightValue * (5.0 / 1023.0);
  // print out the value you read:
  Serial.println(voltage);
if(voltage > 4){
   servoMain.write(180);  
}
else {
  servoMain.write(0);
}
   
}
